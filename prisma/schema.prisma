generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Restaurant {
  id                   String    @id @default(cuid())
  name                 String
  slug                 String    @unique
  logoUrl              String?
  active               Boolean   @default(true)
  serviceChargePercent Float     @default(0)
  qrImageUrl           String?
  receiptConfig        Json?
  currency             String    @default("LAK")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  users      User[]
  shifts     Shift[]
  tables     Table[]
  categories Category[]
  menuItems  MenuItem[]
  orders     Order[]

  @@map("restaurants")
}

model User {
  id           String     @id @default(cuid())
  restaurantId String
  name         String
  pin          String
  role         Role
  active       Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id])
  shiftsOpened Shift[]     @relation("ShiftOpener")
  ordersCreated Order[]    @relation("OrderCreator")
  roundsCreated OrderRound[] @relation("RoundCreator")
  voidLogs     VoidLog[]
  payments     Payment[]

  @@index([restaurantId])
  @@map("users")
}

enum Role {
  ADMIN
  SERVER
  KITCHEN
  CAFE
  WATER
}

model Shift {
  id           String      @id @default(cuid())
  restaurantId String
  openedBy     String
  openedAt     DateTime    @default(now())
  closedAt     DateTime?
  openingCash  Float       @default(0)
  closingCash  Float?
  notes        String?     @db.Text
  status       ShiftStatus @default(OPEN)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  opener     User       @relation("ShiftOpener", fields: [openedBy], references: [id])
  orders     Order[]

  @@index([restaurantId, status])
  @@map("shifts")
}

enum ShiftStatus {
  OPEN
  CLOSED
}

model Table {
  id           String      @id @default(cuid())
  restaurantId String
  number       Int?
  customName   String?
  status       TableStatus @default(AVAILABLE)
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  orders     Order[]

  @@index([restaurantId, status])
  @@map("tables")
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  CHECKOUT
}

model Category {
  id           String   @id @default(cuid())
  restaurantId String
  name         String
  station      Station
  sortOrder    Int      @default(0)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  menuItems  MenuItem[]

  @@index([restaurantId])
  @@map("categories")
}

enum Station {
  KITCHEN
  CAFE
  WATER
}

model MenuItem {
  id           String   @id @default(cuid())
  restaurantId String
  categoryId   String
  name         String
  price        Int
  available    Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant  Restaurant  @relation(fields: [restaurantId], references: [id])
  category    Category    @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]

  @@index([restaurantId, available])
  @@index([categoryId])
  @@map("menu_items")
}

model Order {
  id           String      @id @default(cuid())
  restaurantId String
  tableId      String
  shiftId      String
  status       OrderStatus @default(OPEN)
  guestCount   Int         @default(1)
  createdBy    String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  restaurant Restaurant  @relation(fields: [restaurantId], references: [id])
  table      Table        @relation(fields: [tableId], references: [id])
  shift      Shift        @relation(fields: [shiftId], references: [id])
  creator    User         @relation("OrderCreator", fields: [createdBy], references: [id])
  rounds     OrderRound[]
  payment    Payment?
  splitPayments SplitPayment[]

  @@index([restaurantId, status])
  @@index([tableId, status])
  @@index([shiftId])
  @@map("orders")
}

enum OrderStatus {
  OPEN
  CHECKOUT_REQUESTED
  PAID
  VOIDED
}

model OrderRound {
  id          String   @id @default(cuid())
  orderId     String
  roundNumber Int
  createdBy   String
  createdAt   DateTime @default(now())

  order   Order       @relation(fields: [orderId], references: [id])
  creator User        @relation("RoundCreator", fields: [createdBy], references: [id])
  items   OrderItem[]

  @@index([orderId])
  @@map("order_rounds")
}

model OrderItem {
  id         String     @id @default(cuid())
  roundId    String
  menuItemId String
  quantity   Int        @default(1)
  unitPrice  Int
  notes      String?
  status     ItemStatus @default(PENDING)
  updatedAt  DateTime   @updatedAt

  round    OrderRound @relation(fields: [roundId], references: [id])
  menuItem MenuItem   @relation(fields: [menuItemId], references: [id])
  voidLog  VoidLog?

  @@index([roundId])
  @@index([menuItemId])
  @@map("order_items")
}

enum ItemStatus {
  PENDING
  COOKING
  DONE
  SERVED
  VOIDED
}

model VoidLog {
  id          String   @id @default(cuid())
  orderItemId String   @unique
  voidedBy    String
  reason      String   @db.Text
  voidedAt    DateTime @default(now())

  orderItem OrderItem @relation(fields: [orderItemId], references: [id])
  voidedByUser User   @relation(fields: [voidedBy], references: [id])

  @@map("void_logs")
}

model Payment {
  id                   String       @id @default(cuid())
  orderId              String       @unique
  method               PaymentMethod
  subtotal             Int
  discountType         DiscountType @default(NONE)
  discountValue        Float        @default(0)
  serviceChargePercent Float        @default(0)
  serviceChargeAmount  Int          @default(0)
  total                Int
  cashReceived         Int?
  changeAmount         Int?
  paidAt               DateTime     @default(now())
  paidBy               String

  order    Order @relation(fields: [orderId], references: [id])
  paidByUser User @relation(fields: [paidBy], references: [id])

  @@map("payments")
}

model SplitPayment {
  id           String       @id @default(cuid())
  orderId      String
  splitIndex   Int
  itemIds      Json
  method       PaymentMethod
  subtotal     Int
  discountValue Float       @default(0)
  total        Int
  cashReceived Int?
  changeAmount Int?
  paidAt       DateTime     @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@map("split_payments")
}

enum PaymentMethod {
  CASH
  QR
}

enum DiscountType {
  NONE
  PERCENT
  FIXED
}
